# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # Never expose to client
SUPABASE_JWT_SECRET=your-jwt-secret-here          # Project Settings → API → JWT Secret

# ─── Optional ─────────────────────────────────────────────────────────────────
NTES_API_KEY=                                      # Indian Railways NTES API (optional)

# ─── Render Deployment ────────────────────────────────────────────────────────
RENDER_EXTERNAL_URL=https://railsaathi-z057.onrender.com
# ^ Required for the keep-alive ping in index.js to prevent free-tier sleep
